@using MediatR
@using PDV.Application.Features.Branches.Commands.CreateBranch
@using PDV.Application.Features.Branches.Commands.UpdateBranch
@using PDV.Application.Features.Branches.Dtos
@inject IMediator Mediator
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <div class="d-flex align-center gap-2">
            <MudIcon Icon="@(IsEdit ? Icons.Material.Filled.Edit : Icons.Material.Filled.Store)" Color="Color.Primary" Size="Size.Medium" />
            <MudText Typo="Typo.h6" Class="font-weight-bold">@(IsEdit ? "Editar Sucursal" : "Registrar Nueva Sucursal")</MudText>
        </div>
    </TitleContent>
    <DialogContent>
        <MudForm @ref="branchForm" ValidationDelay="300">
            <MudGrid>
                <!-- Left side: General Info -->
                <MudItem xs="12" md="6">
                    <div class="d-flex flex-column gap-4">
                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold" Color="Color.Primary">DATOS GENERALES</MudText>
                        
                        <MudTextField @bind-Value="Model.Code" Label="Código de Sucursal" 
                                      Variant="Variant.Outlined" Required="true" RequiredError="El código es obligatorio"
                                      Disabled="@IsEdit" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.VpnKey" />
                        
                        <MudTextField @bind-Value="Model.Name" Label="Nombre Comercial" 
                                      Variant="Variant.Outlined" Required="true" RequiredError="El nombre es obligatorio"
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Storefront" />
                        
                        <MudTextField @bind-Value="Model.Address" Label="Calle y Número (Dirección)" 
                                      Variant="Variant.Outlined" Required="true" RequiredError="La dirección es obligatoria"
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Home" />
                    </div>
                </MudItem>
                
                <!-- Right side: Contact / Role -->
                <MudItem xs="12" md="6">
                    <div class="d-flex flex-column gap-4">
                        <MudText Typo="Typo.subtitle2" Class="font-weight-bold" Color="Color.Primary">DATOS DE CONTACTO Y ROL</MudText>
                        
                        <MudTextField @bind-Value="Model.Phone" Label="Teléfono de Contacto" 
                                      Variant="Variant.Outlined" Required="true" RequiredError="El teléfono es obligatorio"
                                      HelperText="Mínimo 10 dígitos numéricos"
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Phone" />
                        
                        <MudTextField @bind-Value="Model.Email" Label="Correo Electrónico" 
                                      Variant="Variant.Outlined" Required="false"
                                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />

                        @if (!IsEdit)
                        {
                            <MudCheckBox @bind-Value="Model.IsMainBranch" Label="¿Es Casa Matriz?" 
                                         Color="Color.Primary" Class="mt-2" />
                        }
                    </div>
                </MudItem>
            </MudGrid>
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel" Style="text-transform: none; font-weight: 500;">Cancelar</MudButton>
        <PdvInteractiveButton Color="Color.Primary" StartIcon="@Icons.Material.Filled.Save" OnClick="Save" IsLoading="@_saving">
            Guardar
        </PdvInteractiveButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public bool IsEdit { get; set; }

    [Parameter]
    public BranchFormModel Model { get; set; } = new();

    private MudForm branchForm = null!;
    private bool _saving = false;

    private void Cancel() => MudDialog.Cancel();

    private async Task Save()
    {
        await branchForm.Validate();
        if (!branchForm.IsValid) return;

        _saving = true;
        try
        {
            if (IsEdit)
            {
                await Mediator.Send(new UpdateBranchCommand(
                    Model.Id,
                    Model.Name,
                    Model.Address,
                    Model.Phone,
                    Model.Email
                ));
            }
            else
            {
                await Mediator.Send(new CreateBranchCommand(
                    Model.Name,
                    Model.Code,
                    Model.Address,
                    Model.Phone,
                    Model.Email,
                    Model.IsMainBranch
                ));
            }
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }

    public class BranchFormModel
    {
        public Guid Id { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Address { get; set; } = string.Empty;
        public string Phone { get; set; } = string.Empty;
        public string? Email { get; set; }
        public bool IsMainBranch { get; set; }
    }
}
