@namespace PDV.WebUI.Components.Shared.UI

<div class="pdv-header-container d-flex align-center justify-space-between flex-wrap gap-4 mb-6" role="banner" aria-label="@Title">
    <div class="d-flex align-center gap-3">
        @if (!string.IsNullOrEmpty(Icon))
        {
            <div class="pdv-header-icon-wrap">
                <MudIcon Icon="@Icon" Size="Size.Large" Color="@IconColor" aria-hidden="true" />
            </div>
        }
        <div>
            <h1 class="pdv-header-title font-weight-bold">@Title</h1>
            @if (!string.IsNullOrEmpty(Subtitle))
            {
                <span class="pdv-header-subtitle">@Subtitle</span>
            }
        </div>
    </div>
    
    <div class="d-flex align-center gap-3 flex-wrap">
        @if (StatusAlert is not null)
        {
            <div class="pdv-header-status-slot">
                @StatusAlert
            </div>
        }
        @if (Actions is not null)
        {
            <div class="pdv-header-actions-slot">
                @Actions
            </div>
        }
    </div>
</div>

@code {
    /// <summary>
    /// The primary title text of the page.
    /// </summary>
    [Parameter]
    [EditorRequired]
    public string Title { get; set; } = string.Empty;

    /// <summary>
    /// Optional contextual explanation or live timestamp text.
    /// </summary>
    [Parameter]
    public string Subtitle { get; set; } = string.Empty;

    /// <summary>
    /// Optional icon to render inside a decorative glassmorphic background box.
    /// </summary>
    [Parameter]
    public string Icon { get; set; } = string.Empty;

    /// <summary>
    /// Color theme of the header icon (default: Color.Primary).
    /// </summary>
    [Parameter]
    public Color IconColor { get; set; } = Color.Primary;

    /// <summary>
    /// Custom action elements (buttons, filters) placed on the right side.
    /// </summary>
    [Parameter]
    public RenderFragment? Actions { get; set; }

    /// <summary>
    /// Optional slot for alert banners or connection monitor status badges.
    /// </summary>
    [Parameter]
    public RenderFragment? StatusAlert { get; set; }
}
