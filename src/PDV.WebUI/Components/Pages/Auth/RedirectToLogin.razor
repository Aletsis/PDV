@inject NavigationManager Navigation

<div class="d-flex flex-column align-center justify-center gap-4" style="min-height: 80vh; background: radial-gradient(circle at 50% 50%, rgba(20, 24, 46, 1) 0%, rgba(8, 10, 20, 1) 100%); border-radius: 24px;">
    <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" Thickness="6" />
    <MudText Typo="Typo.h6" Class="font-weight-bold mud-text-secondary">Redirigiendo al inicio de sesión...</MudText>
</div>

@code {
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            // Realiza una redirección limpia de página completa (forceLoad: true)
            // en OnAfterRender para evitar excepciones en pre-renderizado que detengan al depurador de VS.
            Navigation.NavigateTo($"/login?returnUrl={System.Uri.EscapeDataString(Navigation.Uri)}", forceLoad: true);
        }
    }
}
