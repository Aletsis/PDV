@using MediatR
@using System.Net.Http.Json
@using PDV.Application.Features.Sales.Queries.ListSales
@using PDV.Application.Features.Sales.Queries.GetSale
@using PDV.Application.Features.Sales.Commands.CancelSale
@using PDV.Application.Features.Sales.Commands.ReturnSale
@using PDV.Application.Features.Sales.Commands.CreateInvoice
@using PDV.Application.Features.Sales.Commands.PrintSaleTicket
@using PDV.Application.Features.Sales.Dtos
@using PDV.Application.Features.CashRegisters.Queries.GetCashRegisterByIp
@using PDV.Application.Common.Helpers
@using PDV.Application.Features.CashRegisters.Queries.ListCashRegisters
@using PDV.Application.Features.CashRegisters.Dtos
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject PDV.WebUI.Services.ConnectionMonitor ConnectionMonitor
@inject PDV.WebUI.Services.ShiftSessionService ShiftSession
@inject IHttpContextAccessor HttpContextAccessor
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@implements IDisposable

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h5" Class="font-weight-bold d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Primary" />
            Historial de Notas y Devoluciones (POS)
        </MudText>
    </TitleContent>
    <DialogContent>
        <div class="d-flex flex-column gap-4 py-2" style="position: relative;">
            @if (isWaitingForConnection)
            {
                <div class="d-flex flex-column align-center justify-center pa-8 text-center" style="position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(13, 16, 32, 0.95); z-index: 100; border-radius: 12px; backdrop-filter: blur(10px);">
                    <MudProgressCircular Color="Color.Warning" Size="Size.Large" Indeterminate="true" Class="mb-4" />
                    <MudText Typo="Typo.h5" Class="font-weight-bold mb-2 mud-text-warning">Esperando Conexión al Servidor Central...</MudText>
                    <MudText Typo="Typo.body1" Class="mud-text-secondary mb-6" Style="max-width: 400px;">
                        Se ha pausado la validación del ticket <strong>@searchSeries-@searchFolio</strong>. En cuanto se restablezca la comunicación de red, el ticket se validará automáticamente.
                    </MudText>
                    <MudButton Variant="Variant.Outlined" Color="Color.Error" OnClick="@(() => { isWaitingForConnection = false; })" Style="text-transform: none; border-radius: 8px; font-weight: bold;">
                        Cancelar Espera
                    </MudButton>
                </div>
            }

            <!-- Connection Monitor Alert -->
            <div>
                @if (ConnectionMonitor.IsLocalMode && !ConnectionMonitor.IsConnected)
                {
                    <MudAlert Severity="Severity.Warning" Variant="Variant.Filled" Dense="true" Icon="@Icons.Material.Filled.WifiOff" Style="border-radius: 8px;">
                        Modo Local (SQLite) — Mostrando solo ventas de esta Caja: <strong>@(currentCashRegister?.Name ?? "Local")</strong>
                    </MudAlert>
                }
                else
                {
                    <MudAlert Severity="Severity.Success" Variant="Variant.Filled" Dense="true" Icon="@Icons.Material.Filled.CloudDone" Style="border-radius: 8px;">
                        Modo Online (Sincronizado) — Visualizando ventas globales del sistema
                    </MudAlert>
                }
            </div>

            <!-- Filtering Panel -->
            <MudPaper Class="pa-4 border-solid border mud-border-secondary" Style="border-radius: 12px; background: rgba(255,255,255,0.01);">
                <MudGrid>
                    <MudItem xs="12" md="3">
                        <MudDatePicker @bind-Date="startDate" Label="Fecha de Inicio" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudDatePicker @bind-Date="endDate" Label="Fecha de Fin" Variant="Variant.Outlined" Margin="Margin.Dense" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudSelect T="bool?" @bind-Value="filterPaid" Label="Estado de Pago" Variant="Variant.Outlined" Margin="Margin.Dense">
                            <MudSelectItem Value="@((bool?)null)">Todos los Estados</MudSelectItem>
                            <MudSelectItem Value="@((bool?)true)">Solo Pagadas</MudSelectItem>
                            <MudSelectItem Value="@((bool?)false)">Solo Pendientes</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" md="3" Class="d-flex gap-2">
                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Primary" 
                                   StartIcon="@Icons.Material.Filled.FilterAlt"
                                   OnClick="LoadData" 
                                   FullWidth="true" 
                                   Style="height: 40px; text-transform: none; font-weight: bold; border-radius: 8px;">
                            Filtrar Historial
                        </MudButton>
                    </MudItem>

                    <!-- Fila de búsqueda por Ticket (Serie y Folio) -->
                    <MudItem xs="12" md="3">
                        <MudTextField @bind-Value="searchSeries" Label="Serie del Ticket" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Ej. V" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudNumericField @bind-Value="searchFolio" Label="Folio del Ticket" Variant="Variant.Outlined" Margin="Margin.Dense" Placeholder="Ej. 123" HideSpinButtons="true" />
                    </MudItem>
                    <MudItem xs="12" md="6" Class="d-flex gap-2">
                        <MudButton Variant="Variant.Filled" 
                                   Color="Color.Warning" 
                                   StartIcon="@Icons.Material.Filled.Search"
                                   OnClick="SearchByTicket" 
                                   FullWidth="true" 
                                   Style="height: 40px; text-transform: none; font-weight: bold; border-radius: 8px;"
                                   Disabled="isSearchingTicket">
                            @if (isSearchingTicket)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Buscando Ticket...</span>
                            }
                            else
                            {
                                <span>Buscar Ticket Externo / Local</span>
                            }
                        </MudButton>
                    </MudItem>
                </MudGrid>
            </MudPaper>

            <!-- Data Table Grid -->
            <MudPaper Class="border-solid border mud-border-secondary" Style="border-radius: 12px; overflow: hidden;">
                <MudDataGrid Items="@sales" Filterable="true" Dense="true" Elevation="0" Striped="true" Style="max-height: 400px; overflow-y: auto;">
                    <Columns>
                        <PropertyColumn Property="x => x.Series" Title="Serie" />
                        <PropertyColumn Property="x => x.Folio" Title="Folio" />
                        <PropertyColumn Property="x => x.Date" Title="Fecha y Hora" Format="dd/MM/yyyy HH:mm" />
                        <PropertyColumn Property="x => x.ClientName" Title="Cliente" />
                        <PropertyColumn Property="x => x.PaymentMethod" Title="Método Pago" />
                        <PropertyColumn Property="x => x.TotalAmount" Title="Total Venta" Format="C2" CellStyle="font-weight: bold; color: var(--mud-palette-primary);" />
                        <TemplateColumn Title="Estado de Nota">
                            <CellTemplate>
                                @if (context.Item.IsCancelled)
                                {
                                    <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Filled">Cancelada</MudChip>
                                }
                                else if (context.Item.IsPaid)
                                {
                                    <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Filled">Pagada</MudChip>
                                }
                                else
                                {
                                    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled">Pendiente</MudChip>
                                }
                            </CellTemplate>
                        </TemplateColumn>
                        <TemplateColumn Title="Acciones POS" Style="width: 240px;">
                            <CellTemplate>
                                <div class="d-flex align-center gap-1">
                                    <!-- View Detail -->
                                    <MudTooltip Text="Ver Detalle Ticket">
                                        <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small" OnClick="@(() => ViewSale(context.Item))" />
                                    </MudTooltip>

                                    <!-- Reprint Ticket -->
                                    @if (context.Item.IsPaid && !context.Item.IsCancelled)
                                    {
                                        <MudTooltip Text="Reimprimir Nota">
                                            <MudIconButton Icon="@Icons.Material.Filled.Print" Color="Color.Info" Size="Size.Small" OnClick="@(() => ReprintTicket(context.Item))" />
                                        </MudTooltip>
                                    }

                                    <!-- Cancel Note -->
                                    @if (!context.Item.IsPaid && !context.Item.IsCancelled)
                                    {
                                        <MudTooltip Text="Cancelar Venta">
                                            <MudIconButton Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" OnClick="@(() => CancelSale(context.Item))" />
                                        </MudTooltip>
                                    }

                                    <!-- Actions for paid active sales -->
                                    @if (context.Item.IsPaid && !context.Item.IsCancelled)
                                    {
                                        <!-- Partial / Itemized Refund (Devolución) -->
                                        <MudTooltip Text="Hacer Devolución (Parcial/Total)">
                                            <MudIconButton Icon="@Icons.Material.Filled.Undo" Color="Color.Warning" Size="Size.Small" OnClick="@(() => OpenReturnItemsDialog(context.Item))" />
                                        </MudTooltip>

                                        <!-- Generate Invoice -->
                                        <MudTooltip Text="Facturar Ticket">
                                            <MudIconButton Icon="@Icons.Material.Filled.Receipt" Color="Color.Primary" Size="Size.Small" OnClick="@(() => CreateInvoice(context.Item))" />
                                        </MudTooltip>
                                    }
                                </div>
                            </CellTemplate>
                        </TemplateColumn>
                    </Columns>
                    <PagerContent>
                        <MudDataGridPager T="SaleDto" />
                    </PagerContent>
                </MudDataGrid>
            </MudPaper>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close" Color="Color.Secondary" Variant="Variant.Outlined" Style="text-transform: none; border-radius: 8px; font-weight: bold;">Cerrar Historial</MudButton>
    </DialogActions>
</MudDialog>



@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    private List<SaleDto> sales = new();
    private DateTime? startDate = DateTime.Today;
    private DateTime? endDate = DateTime.Today.AddDays(1);
    private bool? filterPaid = null;

    private CashRegisterDto? currentCashRegister;

    private string searchSeries = string.Empty;
    private int? searchFolio;
    private bool isSearchingTicket = false;
    private bool isWaitingForConnection = false;

    protected override async Task OnInitializedAsync()
    {
        var rawIp = HttpContextAccessor.HttpContext?.Connection.RemoteIpAddress?.MapToIPv4().ToString();
        var clientIp = IpAddressHelper.ResolveClientIp(rawIp);
        
        if (!string.IsNullOrEmpty(clientIp))
        {
            currentCashRegister = await Mediator.Send(new GetCashRegisterByIpQuery(clientIp));
        }



        ConnectionMonitor.OnConnectionStatusChanged += OnConnectionChanged;
        await LoadData();
    }

    private async void OnConnectionChanged(bool isConnected)
    {
        await InvokeAsync(async () => {
            if (isConnected && isWaitingForConnection)
            {
                isWaitingForConnection = false;
                await SearchByTicket();
            }
            else
            {
                await LoadData();
            }
            StateHasChanged();
        });
    }

    private async Task LoadData()
    {
        Guid? cashRegisterFilter = null;
        bool isOffline = ConnectionMonitor.IsLocalMode && !ConnectionMonitor.IsConnected;

        if (isOffline)
        {
            if (currentCashRegister != null)
            {
                cashRegisterFilter = currentCashRegister.Id;
            }

            sales = await Mediator.Send(new ListSalesQuery(
                StartDate: startDate,
                EndDate: endDate,
                IsPaid: filterPaid,
                CashRegisterId: cashRegisterFilter));
        }
        else
        {
            var serverUrl = await ConnectionMonitor.GetResolvedServerUrlAsync();
            if (!string.IsNullOrWhiteSpace(serverUrl))
            {
                try
                {
                    using var httpClient = new HttpClient { Timeout = TimeSpan.FromSeconds(10) };
                    var url = $"{serverUrl.TrimEnd('/')}/api/sync/sales";
                    
                    var queryParams = new List<string>();
                    if (startDate.HasValue) queryParams.Add($"startDate={Uri.EscapeDataString(startDate.Value.ToString("o"))}");
                    if (endDate.HasValue) queryParams.Add($"endDate={Uri.EscapeDataString(endDate.Value.ToString("o"))}");
                    if (filterPaid.HasValue) queryParams.Add($"isPaid={filterPaid.Value}");
                    
                    if (queryParams.Any())
                    {
                        url += "?" + string.Join("&", queryParams);
                    }

                    var response = await httpClient.GetAsync(url);
                    if (response.IsSuccessStatusCode)
                    {
                        sales = await response.Content.ReadFromJsonAsync<List<SaleDto>>() ?? new();
                    }
                    else
                    {
                        Snackbar.Add($"Error al consultar el servidor central: {response.ReasonPhrase}", Severity.Warning);
                    }
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Error al conectar al servidor central: {ex.Message}. Cargando datos locales...", Severity.Warning);
                    sales = await Mediator.Send(new ListSalesQuery(
                        StartDate: startDate,
                        EndDate: endDate,
                        IsPaid: filterPaid,
                        CashRegisterId: null));
                }
            }
            else
            {
                sales = await Mediator.Send(new ListSalesQuery(
                    StartDate: startDate,
                    EndDate: endDate,
                    IsPaid: filterPaid,
                    CashRegisterId: null));
            }
        }
    }

    private async Task<bool> RequestAuthorizationAsync(string actionName)
    {
        var parameters = new DialogParameters { ["ActionName"] = actionName };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = false, BackdropClick = false };
        var dialog = await DialogService.ShowAsync<PDV.WebUI.Components.Pages.Auth.AuthorizationDialog>("Autorización Requerida", parameters, options);
        var result = await dialog.Result;
        return result != null && !result.Canceled && result.Data is bool authorized && authorized;
    }

    private async Task ViewSale(SaleDto sale)
    {
        var exists = await EnsureSaleExistsLocally(sale.Id);
        if (exists)
        {
            MudDialog.Close(DialogResult.Ok(sale));
        }
    }

    private async Task ReprintTicket(SaleDto sale)
    {
        var exists = await EnsureSaleExistsLocally(sale.Id);
        if (!exists) return;

        var authorized = await RequestAuthorizationAsync("Reimprimir ticket anterior");
        if (!authorized) return;

        try
        {
            var registerId = ShiftSession.ActiveCashRegisterId ?? Guid.Empty;
            await Mediator.Send(new PrintSaleTicketCommand(sale.Id, CashRegisterId: registerId));
            Snackbar.Add("Comando de reimpresión enviado a la impresora", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al imprimir: {ex.Message}", Severity.Error);
        }
    }

    private async Task CancelSale(SaleDto sale)
    {
        var exists = await EnsureSaleExistsLocally(sale.Id);
        if (!exists) return;

        var authorized = await RequestAuthorizationAsync("Cancelar venta activa o emitida");
        if (!authorized) return;

        bool? result = await DialogService.ShowMessageBox(
            "Cancelar Venta",
            $"¿Estás seguro que deseas cancelar la venta {sale.SaleNumber}?",
            yesText: "Cancelar Venta", cancelText: "No");

        if (result == true)
        {
            var parameters = new DialogParameters { ["Title"] = "Razón de cancelación", ["Message"] = "Ingrese la razón de la cancelación:" };
            var dialog = await DialogService.ShowAsync<InputDialog>("Razón de cancelación", parameters);
            var dialogResult = await dialog.Result;
            if (dialogResult != null && !dialogResult.Canceled && dialogResult.Data is string reason && !string.IsNullOrWhiteSpace(reason))
            {
                try
                {
                    var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
                    var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
                    await Mediator.Send(new CancelSaleCommand(sale.Id, reason, userId));
                    Snackbar.Add("Venta cancelada exitosamente", Severity.Success);
                    await LoadData();
                }
                catch (InvalidOperationException ex)
                {
                    Snackbar.Add(ex.Message, Severity.Error);
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Error: {ex.Message}", Severity.Error);
                }
            }
        }
    }

    private async Task OpenReturnItemsDialog(SaleDto sale)
    {
        var exists = await EnsureSaleExistsLocally(sale.Id);
        if (!exists) return;

        var authorized = await RequestAuthorizationAsync("Procesar devolución de mercancía");
        if (!authorized) return;

        var detail = await Mediator.Send(new GetSaleQuery(sale.Id));
        if (detail == null)
        {
            Snackbar.Add("No se pudo cargar la información de la venta.", Severity.Error);
            return;
        }

        var parameters = new DialogParameters { ["SaleDetail"] = detail };
        var dialog = await DialogService.ShowAsync<ReturnItemsDialog>("Procesar Devolución", parameters, new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        var result = await dialog.Result;

        if (result != null && !result.Canceled && result.Data is bool success && success)
        {
            await LoadData();
        }
    }

    private async Task CreateInvoice(SaleDto sale)
    {
        var exists = await EnsureSaleExistsLocally(sale.Id);
        if (!exists) return;

        var invoiceType = await DialogService.ShowMessageBox(
            "Tipo de Factura",
            "¿Qué tipo de factura desea crear?",
            yesText: "Por Cliente", cancelText: "Global", noText: "Cancelar");

        if (invoiceType == null) return;

        bool isGlobal = invoiceType == false;

        try
        {
            var command = new CreateInvoiceCommand
            {
                SaleId = sale.Id,
                IsGlobal = isGlobal,
                TaxRate = 0.16m
            };
            var invoiceId = await Mediator.Send(command);
            Snackbar.Add($"Factura creada exitosamente. ID: {invoiceId}", Severity.Success);
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
    }

    private void Close() => MudDialog.Close(DialogResult.Ok(true));

    public void Dispose()
    {
        ConnectionMonitor.OnConnectionStatusChanged -= OnConnectionChanged;
    }

    private async Task<bool> EnsureSaleExistsLocally(Guid saleId)
    {
        var localSale = await Mediator.Send(new GetSaleQuery(saleId));
        if (localSale != null)
        {
            return true;
        }

        bool isOffline = ConnectionMonitor.IsLocalMode && !ConnectionMonitor.IsConnected;
        if (isOffline)
        {
            Snackbar.Add("No se pudo cargar la información de la venta (Modo Offline).", Severity.Error);
            return false;
        }

        try
        {
            var serverUrl = await ConnectionMonitor.GetResolvedServerUrlAsync();
            if (!string.IsNullOrWhiteSpace(serverUrl))
            {
                using var httpClient = new HttpClient { Timeout = TimeSpan.FromSeconds(10) };
                var endpoint = $"{serverUrl.TrimEnd('/')}/api/sync/sales/{saleId}";
                var response = await httpClient.GetAsync(endpoint);
                if (response.IsSuccessStatusCode)
                {
                    var saleDetail = await response.Content.ReadFromJsonAsync<SaleDetailDto>();
                    if (saleDetail != null)
                    {
                        var importCommand = new PDV.Application.Features.Sales.Commands.ImportSale.ImportSaleCommand(saleDetail);
                        var importSuccess = await Mediator.Send(importCommand);
                        return importSuccess;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al importar la venta desde el servidor: {ex.Message}", Severity.Error);
        }

        return false;
    }

    private async Task SearchByTicket()
    {
        if (string.IsNullOrWhiteSpace(searchSeries) || !searchFolio.HasValue)
        {
            Snackbar.Add("Debe ingresar la serie y el folio del ticket.", Severity.Warning);
            return;
        }

        bool isOffline = ConnectionMonitor.IsLocalMode && !ConnectionMonitor.IsConnected;

        if (isOffline)
        {
            bool? confirm = await DialogService.ShowMessageBox(
                "Sin Conexión al Servidor",
                "No hay conexión con el servidor central para validar tickets externos de otras cajas. ¿Deseas esperar a que regrese la conexión para validar automáticamente?",
                yesText: "Esperar Conexión",
                noText: "Cancelar"
            );

            if (confirm == true)
            {
                isWaitingForConnection = true;
                StateHasChanged();
            }
            return;
        }

        isSearchingTicket = true;
        StateHasChanged();

        try
        {
            var serverUrl = await ConnectionMonitor.GetResolvedServerUrlAsync();
            SaleDetailDto? saleDetail = null;

            if (!string.IsNullOrWhiteSpace(serverUrl))
            {
                using var httpClient = new HttpClient { Timeout = TimeSpan.FromSeconds(10) };
                var endpoint = $"{serverUrl.TrimEnd('/')}/api/sync/sales/by-ticket?series={Uri.EscapeDataString(searchSeries)}&folio={searchFolio.Value}";
                
                var response = await httpClient.GetAsync(endpoint);
                if (response.IsSuccessStatusCode)
                {
                    saleDetail = await response.Content.ReadFromJsonAsync<SaleDetailDto>();
                }
                else if (response.StatusCode == System.Net.HttpStatusCode.NotFound)
                {
                    Snackbar.Add("Ticket no encontrado en el Servidor Central.", Severity.Error);
                }
                else
                {
                    Snackbar.Add($"Error del servidor ({response.StatusCode}) al buscar el ticket.", Severity.Error);
                }
            }
            else
            {
                saleDetail = await Mediator.Send(new PDV.Application.Features.Sales.Queries.GetSaleByTicket.GetSaleByTicketQuery(searchSeries, searchFolio.Value));
            }

            if (saleDetail != null)
            {
                if (ConnectionMonitor.IsLocalMode)
                {
                    var importCommand = new PDV.Application.Features.Sales.Commands.ImportSale.ImportSaleCommand(saleDetail);
                    var importSuccess = await Mediator.Send(importCommand);
                    if (importSuccess)
                    {
                        Snackbar.Add($"Ticket #{searchSeries}-{searchFolio} importado localmente con éxito.", Severity.Success);
                    }
                }

                var mappedSale = new SaleDto
                {
                    Id = saleDetail.Id,
                    SaleNumber = saleDetail.SaleNumber,
                    Date = saleDetail.Date,
                    TotalAmount = saleDetail.TotalAmount,
                    PaymentMethod = saleDetail.PaymentMethod,
                    ClientId = saleDetail.ClientId,
                    ClientName = saleDetail.ClientName,
                    IsPaid = saleDetail.IsPaid,
                    IsCancelled = saleDetail.IsCancelled,
                    IsReturned = saleDetail.IsReturned,
                    ItemCount = saleDetail.Items.Count,
                    Series = saleDetail.Series,
                    Folio = saleDetail.Folio
                };

                sales = new List<SaleDto> { mappedSale };
                Snackbar.Add($"Ticket encontrado: {mappedSale.SaleNumber}", Severity.Info);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al buscar ticket: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSearchingTicket = false;
            StateHasChanged();
        }
    }
}
