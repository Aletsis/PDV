@page "/products"
@using MediatR
@using PDV.Application.Features.Products.Queries.GetProducts
@using PDV.Application.Features.Products.Commands.CreateProduct
@using PDV.Application.Features.Products.Commands.UpdateProduct
@using PDV.Application.Features.Products.Commands.DeleteProduct
@using PDV.Application.Features.Products.Dtos
@using PDV.Application.Features.Sync.Queries
@inject IMediator Mediator
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject PDV.WebUI.Services.ConnectionMonitor ConnectionMonitor
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@implements IDisposable

<PageTitle>Catálogo de Productos</PageTitle>

<div class="d-flex flex-column gap-6">
    <!-- Page Header & Mode Monitor -->
    <PdvHeader Title="Catálogo de Productos"
               Subtitle="Administra los productos del catálogo, sus precios, costos, impuestos y control de stock mínimo."
               Icon="@Icons.Material.Filled.Inventory"
               IconColor="Color.Primary">
        <StatusAlert>
            @if (isLocalMode)
            {
                <div class="local-mode-monitor d-flex align-center gap-3 px-4 py-2 border-dashed rounded-lg">
                    <div class="d-flex flex-column">
                        <span class="monitor-label">Base de Datos</span>
                        <span class="monitor-val font-weight-medium">Local (SQLite)</span>
                    </div>
                    <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />
                    <div class="d-flex flex-column align-end">
                        <span class="monitor-label">Modo Operativo</span>
                        <div class="d-flex align-center gap-1">
                            <MudIcon Icon="@Icons.Material.Filled.CloudDone" Size="Size.Small" Color="Color.Success" />
                            <span class="monitor-val-accent text-success font-weight-bold">Lectura Offline</span>
                        </div>
                    </div>
                </div>
            }
        </StatusAlert>
    </PdvHeader>

    <!-- Server Only Mode Alert -->
    @if (isLocalMode)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Square="false" Class="border-solid" Style="border-radius: 8px; border-width: 1px;">
            La administración de productos se realiza únicamente a nivel servidor. En esta terminal local, los productos se actualizan automáticamente y están disponibles para la venta sin conexión.
        </MudAlert>
    }

    <!-- Metrics Cards Grid -->
    <MudGrid>
        <MudItem xs="12" sm="6" md="3">
            <PdvKpiCard Title="Total Productos"
                       Value="@totalProductsCount.ToString()"
                       Icon="@Icons.Material.Filled.Inventory"
                       IconColor="Color.Primary"
                       IsLoading="@isLoading" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <PdvKpiCard Title="Activos"
                       Value="@activeProductsCount.ToString()"
                       Icon="@Icons.Material.Filled.CheckCircle"
                       IconColor="Color.Success"
                       IsLoading="@isLoading"
                       GradientType="PdvKpiCard.KpiGradientType.Success" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <PdvKpiCard Title="Bajo Stock"
                       Value="@lowStockProductsCount.ToString()"
                       Icon="@Icons.Material.Filled.TrendingDown"
                       IconColor="Color.Warning"
                       IsLoading="@isLoading"
                       GradientType="PdvKpiCard.KpiGradientType.Warning" />
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <PdvKpiCard Title="Sin Stock"
                       Value="@outOfStockProductsCount.ToString()"
                       Icon="@Icons.Material.Filled.Warning"
                       IconColor="Color.Error"
                       IsLoading="@isLoading"
                       GradientType="PdvKpiCard.KpiGradientType.Error" />
        </MudItem>
    </MudGrid>

    <!-- Main Data Section -->
    <MudPaper Class="p-4" Style="border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.05);">
        <!-- Table Toolbar -->
        <div class="d-flex align-center justify-space-between flex-wrap gap-4 mb-4">
            <div class="d-flex align-center gap-3 flex-grow-1" Style="max-width: 600px;">
                <MudTextField @bind-Value="searchString" Placeholder="Buscar por Nombre, Código o Código de Barras..." 
                               Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                               IconSize="Size.Medium" Immediate="true" Variant="Variant.Outlined" Margin="Margin.Dense"
                               Clearable="true" Class="flex-grow-1" />
                
                <MudSelect T="bool?" Value="filterActive" ValueChanged="OnFilterActiveChanged" Label="Estado" 
                           Variant="Variant.Outlined" Margin="Margin.Dense" Style="max-width: 150px;">
                    <MudSelectItem T="bool?" Value="@((bool?)null)">Todos</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@(true)">Activos</MudSelectItem>
                    <MudSelectItem T="bool?" Value="@(false)">Inactivos</MudSelectItem>
                </MudSelect>
            </div>
            
            @if (!isLocalMode)
            {
                <PdvInteractiveButton UseGradient="true" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateDialog">
                    Nuevo Producto
                </PdvInteractiveButton>
            }
        </div>

        <!-- Data Grid wrapped in State Container -->
        <PdvStateContainer IsLoading="@isLoading"
                            IsEmpty="@(!filteredProducts.Any())"
                            EmptyTitle="Sin productos"
                            EmptyMessage="No se encontraron productos registrados en el catálogo que coincidan con los filtros."
                            EmptyIcon="@Icons.Material.Filled.Inventory"
                            SkeletonRows="6"
                            SkeletonColumns="7">
            <MudDataGrid T="ProductDto" Items="@filteredProducts" Filterable="false" Sortable="true" Hover="true" Striped="true" 
                         Dense="false" Elevation="0" Class="border border-solid rounded-lg">
                <Columns>
                    <PropertyColumn Property="x => x.Code" Title="Código" CellStyle="font-weight: 600;" />
                    <PropertyColumn Property="x => x.Barcode" Title="Código Barras" />
                    <PropertyColumn Property="x => x.Name" Title="Nombre" CellStyle="font-weight: 600; color: var(--mud-palette-text-primary);" />
                    <PropertyColumn Property="x => x.Category" Title="Categoría" />
                    <PropertyColumn Property="x => x.Price" Title="Precio Venta" Format="C2" />
                    <PropertyColumn Property="x => x.Cost" Title="Costo" Format="C2" />
                    
                    <!-- Stock status column with custom warnings -->
                    <TemplateColumn Title="Stock">
                        <CellTemplate>
                            @{
                                var p = context.Item;
                                decimal threshold = 5;
                                if (decimal.TryParse(Configuration["InventorySettings:DefaultLowStockThreshold"], out var pt))
                                {
                                    threshold = pt;
                                }
                                var isLow = p.IsActive && (p.MinStock > 0 ? p.Stock <= p.MinStock : p.Stock <= threshold);
                                var isOut = p.IsActive && p.Stock <= 0;
                            }
                            @if (isOut)
                            {
                                <MudChip T="string" Color="Color.Error" Size="Size.Small" Variant="Variant.Filled" Icon="@Icons.Material.Filled.Error" Class="font-weight-medium">Agotado</MudChip>
                            }
                            else if (isLow)
                            {
                                <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Filled" Icon="@Icons.Material.Filled.TrendingDown" Class="font-weight-medium">@p.Stock (Bajo)</MudChip>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2">@p.Stock</MudText>
                            }
                        </CellTemplate>
                    </TemplateColumn>

                    <TemplateColumn Title="Estado">
                        <CellTemplate>
                            @if (context.Item.IsActive)
                            {
                                <MudChip T="string" Color="Color.Success" Variant="Variant.Text" Size="Size.Small" Icon="@Icons.Material.Filled.CheckCircle" Class="font-weight-medium">Activo</MudChip>
                            }
                            else
                            {
                                <MudChip T="string" Color="Color.Default" Variant="Variant.Text" Size="Size.Small" Icon="@Icons.Material.Filled.Cancel" Class="font-weight-medium">Inactivo</MudChip>
                            }
                        </CellTemplate>
                    </TemplateColumn>

                    @if (!isLocalMode)
                    {
                        <TemplateColumn Title="Acciones" HeaderStyle="width: 120px;" CellClass="d-flex justify-end gap-1">
                            <CellTemplate>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small" 
                                               OnClick="@(() => OpenEditDialog(context.Item))" Style="background-color: rgba(33, 150, 243, 0.05);" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" 
                                               OnClick="@(() => DeleteProduct(context.Item))" Style="background-color: rgba(244, 67, 54, 0.05);" />
                            </CellTemplate>
                        </TemplateColumn>
                    }
                </Columns>
                <PagerContent>
                    <MudDataGridPager T="ProductDto" />
                </PagerContent>
            </MudDataGrid>
        </PdvStateContainer>
    </MudPaper>
</div>

@code {
    private List<ProductDto> products = new();
    private bool isLocalMode = false;
    private bool isLoading = false;

    // Stats variables
    private int totalProductsCount = 0;
    private int activeProductsCount = 0;
    private int lowStockProductsCount = 0;
    private int outOfStockProductsCount = 0;

    // Search and filter parameters
    private string searchString = "";
    private bool? filterActive = true; // Default to showing only Active products

    private IEnumerable<ProductDto> filteredProducts => products
        .Where(p => 
            // Text Search filter
            (string.IsNullOrWhiteSpace(searchString) || 
             p.Name.Contains(searchString, StringComparison.OrdinalIgnoreCase) || 
             p.Code.Contains(searchString, StringComparison.OrdinalIgnoreCase) || 
             (p.Barcode != null && p.Barcode.Contains(searchString, StringComparison.OrdinalIgnoreCase))) 
            &&
            // Active state filter
            (filterActive == null || p.IsActive == filterActive)
        );

    protected override async Task OnInitializedAsync()
    {
        ConnectionMonitor.OnConnectionStatusChanged += OnConnectionStatusChanged;
        await LoadSyncStatus();
        await LoadData();
    }

    private void OnConnectionStatusChanged(bool isConnected)
    {
        InvokeAsync(async () => {
            await LoadSyncStatus();
            StateHasChanged();
        });
    }

    private async Task LoadSyncStatus()
    {
        try
        {
            var syncStatus = await Mediator.Send(new GetSyncStatusQuery());
            isLocalMode = syncStatus.IsLocalMode;
        }
        catch (Exception)
        {
            isLocalMode = false;
        }
    }

    private async Task LoadData()
    {
        isLoading = true;
        try
        {
            products = await Mediator.Send(new GetProductsQuery());
            CalculateMetrics();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar productos: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }

    private void CalculateMetrics()
    {
        totalProductsCount = products.Count;
        activeProductsCount = products.Count(p => p.IsActive);
        
        decimal threshold = 5;
        if (decimal.TryParse(Configuration["InventorySettings:DefaultLowStockThreshold"], out var parsedThreshold))
        {
            threshold = parsedThreshold;
        }

        lowStockProductsCount = products.Count(p => 
            p.IsActive && 
            (p.MinStock > 0 ? p.Stock <= p.MinStock : p.Stock <= threshold)
        );
        
        outOfStockProductsCount = products.Count(p => p.IsActive && p.Stock <= 0);
    }

    private void OnFilterActiveChanged(bool? val)
    {
        filterActive = val;
    }

    private async Task OpenCreateDialog()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = DialogService.Show<ProductDialog>("Nuevo Producto", options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is ProductDialog.ProductViewModel model1)
        {
            var model = model1;
            var command = new CreateProductCommand
            {
                Name = model.Name,
                Code = model.Code,
                Plu = model.Plu,
                Barcode = model.Barcode,
                Description = model.Description,
                Price = model.Price,
                Cost = model.Cost,
                WholesalePrice = model.WholesalePrice,
                WholesaleMinQuantity = model.WholesaleMinQuantity,
                Stock = model.Stock,
                MinStock = model.MinStock,
                Category = model.Category,
                SaleType = model.SaleType,
                TaxRate = model.TaxRate,
                SatCode = model.SatCode,
                Type = model.Type,
                ControlExistencia = model.ControlExistencia,
                SaleUnitId = model.SaleUnitId,
                SaleUnitName = model.SaleUnitName,
                XmlUnitId = model.XmlUnitId,
                Department = model.Department,
                Clasificacion1Id = model.Clasificacion1Id,
                Clasificacion5Id = model.Clasificacion5Id
            };

            try
            {
                await Mediator.Send(command);
                Snackbar.Add("Producto creado exitosamente", Severity.Success);
                await LoadData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error al crear producto: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task OpenEditDialog(ProductDto product)
    {
        var parameters = new DialogParameters();
        parameters.Add("Model", new ProductDialog.ProductViewModel
        {
            Id = product.Id,
            Name = product.Name,
            Code = product.Code,
            Plu = product.Plu,
            Barcode = product.Barcode,
            Description = product.Description,
            Price = product.Price,
            Cost = product.Cost,
            WholesalePrice = product.WholesalePrice,
            WholesaleMinQuantity = product.WholesaleMinQuantity,
            Stock = product.Stock,
            MinStock = product.MinStock,
            Category = product.Category,
            SaleType = product.SaleType,
            TaxRate = product.TaxRate,
            SatCode = product.SatCode,
            Type = product.Type,
            ControlExistencia = product.ControlExistencia,
            SaleUnitId = product.SaleUnitId,
            SaleUnitName = product.SaleUnitName,
            XmlUnitId = product.XmlUnitId,
            Department = product.Department,
            Clasificacion1Id = product.Clasificacion1Id,
            Clasificacion5Id = product.Clasificacion5Id
        });

        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium, FullWidth = true };
        var dialog = DialogService.Show<ProductDialog>("Editar Producto", parameters, options);
        var result = await dialog.Result;

        if (!result.Canceled && result.Data is ProductDialog.ProductViewModel model2)
        {
            var model = model2;
            var command = new UpdateProductCommand
            {
                Id = model.Id,
                Name = model.Name,
                Code = model.Code,
                Plu = model.Plu,
                Barcode = model.Barcode,
                Description = model.Description,
                Price = model.Price,
                Cost = model.Cost,
                WholesalePrice = model.WholesalePrice,
                WholesaleMinQuantity = model.WholesaleMinQuantity,
                Stock = model.Stock,
                MinStock = model.MinStock,
                Category = model.Category,
                SaleType = model.SaleType,
                TaxRate = model.TaxRate,
                SatCode = model.SatCode,
                Type = model.Type,
                ControlExistencia = model.ControlExistencia,
                SaleUnitId = model.SaleUnitId,
                SaleUnitName = model.SaleUnitName,
                XmlUnitId = model.XmlUnitId,
                Department = model.Department,
                Clasificacion1Id = model.Clasificacion1Id,
                Clasificacion5Id = model.Clasificacion5Id
            };

            try
            {
                await Mediator.Send(command);
                Snackbar.Add("Producto actualizado exitosamente", Severity.Success);
                await LoadData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error al actualizar producto: {ex.Message}", Severity.Error);
            }
        }
    }

    private async Task DeleteProduct(ProductDto product)
    {
        bool? result = await DialogService.ShowMessageBox(
            "Eliminar Producto", 
            $"¿Estás seguro que deseas eliminar {product.Name}?", 
            yesText: "Eliminar", cancelText: "Cancelar");

        if (result == true)
        {
            try
            {
                await Mediator.Send(new DeleteProductCommand(product.Id));
                Snackbar.Add("Producto eliminado exitosamente", Severity.Success);
                await LoadData();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error al eliminar producto: {ex.Message}", Severity.Error);
            }
        }
    }

    public void Dispose()
    {
        ConnectionMonitor.OnConnectionStatusChanged -= OnConnectionStatusChanged;
    }
}
