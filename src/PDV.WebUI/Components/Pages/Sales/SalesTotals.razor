@using PDV.Domain.ValueObjects

<div class="mt-4">
    <!-- Totals breakdown -->
    <MudGrid Class="pa-2 mud-text-secondary" Justify="Justify.FlexEnd">
        <MudItem xs="6" md="4" Class="text-right pa-1">
            <MudText Typo="Typo.body2">Subtotal:</MudText>
        </MudItem>
        <MudItem xs="6" md="3" Class="text-right pa-1 font-weight-bold">
            <MudText Typo="Typo.body2">$@Subtotal.ToString("F2")</MudText>
        </MudItem>
    </MudGrid>
    <MudGrid Class="pa-2 mud-text-secondary" Justify="Justify.FlexEnd">
        <MudItem xs="6" md="4" Class="text-right pa-1">
            <MudText Typo="Typo.body2">Impuestos (IVA):</MudText>
        </MudItem>
        <MudItem xs="6" md="3" Class="text-right pa-1 font-weight-bold">
            <MudText Typo="Typo.body2">$@TotalTax.ToString("F2")</MudText>
        </MudItem>
    </MudGrid>

    <MudDivider Class="my-4" />

    <!-- Totals Footer -->
    <div class="d-flex justify-end align-center pa-2">
        <div class="text-right">
             <MudText Typo="Typo.caption" Class="mud-text-secondary">TOTAL DE VENTA</MudText>
             <MudText Typo="Typo.h3" Class="font-weight-bold mud-text-primary">$@TotalAmount.ToString("F2")</MudText>
        </div>
    </div>

    <!-- Checkout & Suspend Cart Action Buttons -->
    <MudStack Row="true" Spacing="2" Class="mt-4">
        @if (IsHistoricalView)
        {
            <!-- Close / Return -->
            <MudButton Variant="Variant.Outlined" 
                       Color="Color.Secondary" 
                       Size="Size.Large" 
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       Class="py-3 px-6 font-weight-bold" 
                       OnClick="OnCloseViewClicked"
                       Style="text-transform: none; border-radius: 8px;">
                Salir de Vista
            </MudButton>

            @if (IsReturnable)
            {
                <!-- Return items -->
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Warning" 
                           Size="Size.Large" 
                           StartIcon="@Icons.Material.Filled.Undo"
                           Class="py-3 px-6 font-weight-bold" 
                           OnClick="OnReturnClicked"
                           Style="text-transform: none; border-radius: 8px;">
                    Devolver
                </MudButton>
            }

            <!-- Reprint Ticket -->
            <MudButton Variant="Variant.Filled" 
                       Color="Color.Info" 
                       Size="Size.Large" 
                       StartIcon="@Icons.Material.Filled.Print"
                       Class="py-3 flex-grow-1 font-weight-bold" 
                       OnClick="OnReprintClicked"
                       Style="text-transform: none; border-radius: 8px;">
                Reimprimir Ticket
            </MudButton>
        }
        else
        {
            <!-- Suspend note -->
            <MudButton Variant="Variant.Outlined" 
                       Color="Color.Warning" 
                       Size="Size.Large" 
                       StartIcon="@Icons.Material.Filled.Pause"
                       Class="py-3 px-6 font-weight-bold" 
                       Disabled="!HasItems"
                       OnClick="OnSuspendClicked"
                       Style="text-transform: none; border-radius: 8px;">
                Nueva Venta
            </MudButton>

            <!-- Clear cart -->
            <MudButton Variant="Variant.Outlined" 
                       Color="Color.Error" 
                       Size="Size.Large" 
                       StartIcon="@Icons.Material.Filled.Cancel"
                       Class="py-3 px-6 font-weight-bold" 
                       Disabled="!HasItems"
                       OnClick="OnCancelClicked"
                       Style="text-transform: none; border-radius: 8px;">
                Cancelar
            </MudButton>

            <!-- Unified Cobrar button -->
            <MudButton Variant="Variant.Filled" 
                       Color="Color.Success" 
                       Size="Size.Large" 
                       StartIcon="@Icons.Material.Filled.CheckCircle"
                       Class="py-3 flex-grow-1 font-weight-bold" 
                       Disabled="!HasItems"
                       OnClick="OnCheckoutClicked"
                       Style="text-transform: none; border-radius: 8px;">
                Cobrar (F8)
            </MudButton>
        }
    </MudStack>
</div>

@code {
    [Parameter] public Guid? ActiveSaleId { get; set; }
    [Parameter] public decimal Subtotal { get; set; }
    [Parameter] public decimal TotalTax { get; set; }
    [Parameter] public decimal TotalAmount { get; set; }
    [Parameter] public bool HasItems { get; set; }

    [Parameter] public bool IsHistoricalView { get; set; }
    [Parameter] public bool IsReturnable { get; set; }

    [Parameter] public EventCallback OnCheckoutClicked { get; set; }
    [Parameter] public EventCallback OnCancelClicked { get; set; }
    [Parameter] public EventCallback OnSuspendClicked { get; set; }

    [Parameter] public EventCallback OnReturnClicked { get; set; }
    [Parameter] public EventCallback OnCloseViewClicked { get; set; }
    [Parameter] public EventCallback OnReprintClicked { get; set; }
}
