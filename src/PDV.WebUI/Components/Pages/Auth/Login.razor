@page "/login"
@using Microsoft.AspNetCore.Components.Authorization
@layout Layout.LoginLayout
@inject NavigationManager Navigation

<PageTitle>Iniciar Sesión — PDV</PageTitle>

<style>
    .login-container {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: radial-gradient(circle at 50% 50%, rgba(20, 24, 46, 1) 0%, rgba(8, 10, 20, 1) 100%);
        border-radius: 0px;
        padding: 16px;
    }
    .login-card {
        background: rgba(255, 255, 255, 0.02);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
        border: 1px solid rgba(255, 255, 255, 0.07);
        border-radius: 24px;
        padding: 48px 40px;
        box-shadow: 0 16px 40px rgba(0, 0, 0, 0.6);
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }
    .login-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 20px 48px rgba(124, 77, 255, 0.12);
    }
    .gradient-header-text {
        background: linear-gradient(135deg, #a78bfa 0%, #818cf8 60%, #6366f1 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        font-weight: 800;
        letter-spacing: -0.5px;
    }
    .input-group {
        position: relative;
        margin-bottom: 24px;
    }
    .custom-input {
        width: 100%;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 14px 16px 14px 44px;
        color: #ffffff;
        font-size: 1rem;
        transition: all 0.25s ease;
    }
    .custom-input:focus {
        outline: none;
        border-color: #7c4dff;
        background: rgba(124, 77, 255, 0.04);
        box-shadow: 0 0 10px rgba(124, 77, 255, 0.2);
    }
    .input-icon {
        position: absolute;
        left: 14px;
        top: 50%;
        transform: translateY(-50%);
        color: rgba(255, 255, 255, 0.4);
        pointer-events: none;
        transition: color 0.25s ease;
    }
    .custom-input:focus + .input-icon {
        color: #b794f4;
    }
    .btn-login {
        background: linear-gradient(135deg, #7c4dff 0%, #6366f1 100%);
        color: #ffffff;
        font-weight: 700;
        letter-spacing: 0.5px;
        text-transform: uppercase;
        border-radius: 12px;
        padding: 14px;
        width: 100%;
        border: none;
        cursor: pointer;
        box-shadow: 0 4px 15px rgba(124, 77, 255, 0.3);
        transition: all 0.2s ease;
    }
    .btn-login:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(124, 77, 255, 0.45);
        background: linear-gradient(135deg, #8b5cf6 0%, #4f46e5 100%);
    }
    .btn-login:active {
        transform: translateY(1px);
    }
</style>

<div class="login-container">
    <MudGrid Justify="Justify.Center">
        <MudItem xs="12" sm="8" md="6" lg="4">
            <div class="login-card">
                <div class="text-center mb-6">
                    <MudIcon Icon="@Icons.Material.Filled.Lock" Style="font-size: 40px; color: #a78bfa;" Class="mb-2" />
                    <MudText Typo="Typo.h4" Class="gradient-header-text">Iniciar Sesión</MudText>
                    <MudText Typo="Typo.body2" Class="text-white-50 mt-1">Ingresa al sistema de punto de venta</MudText>
                </div>

                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mb-4" Style="border-radius: 12px; background: rgba(244, 67, 54, 0.05);">
                        @ErrorMessage
                    </MudAlert>
                }

                <form action="/Account/Login" method="post">
                    <input type="hidden" name="returnUrl" value="@ReturnUrl" />
                    
                    <div class="input-group">
                        <input class="custom-input" 
                               type="text" 
                               name="email" 
                               placeholder="Email o Usuario" 
                               required />
                        <span class="input-icon">
                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Medium" />
                        </span>
                    </div>

                    <div class="input-group mb-6">
                        <input class="custom-input" 
                               type="password" 
                               name="password" 
                               placeholder="Contraseña" 
                               required />
                        <span class="input-icon">
                            <MudIcon Icon="@Icons.Material.Filled.VpnKey" Size="Size.Medium" />
                        </span>
                    </div>

                    <button type="submit" class="btn-login">
                        Ingresar al Sistema
                    </button>
                </form>
            </div>
        </MudItem>
    </MudGrid>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; } = "/";

    private string ErrorMessage => Error switch
    {
        "InvalidCredentials" => "Usuario o contraseña incorrectos. Intente de nuevo.",
        "InactiveAccount" => "Acceso denegado: Esta cuenta de usuario se encuentra inactiva.",
        _ => ""
    };
}

